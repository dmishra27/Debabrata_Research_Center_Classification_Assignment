# Copy this file to .env and fill in values before running docker-compose
# ─────────────────────────────────────────────────────────────────────────────

# Path to the serialised model bundle (relative to container WORKDIR)
MODEL_PATH=model_bundle.pkl

# Uvicorn settings (override at runtime if needed)
HOST=0.0.0.0
PORT=8000

# Logging level: debug | info | warning | error
LOG_LEVEL=info
